{
  "name": "open-agent-teams",
  "private": true,
  "description": "Open-Agent-Teams：Agent Teams 协同抽象框架与 Hermes 集成基座（pnpm 多包工作区）",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "core:build": "pnpm --filter @open-agent-teams/core run build",
    "core:check": "pnpm --filter @open-agent-teams/core run check",
    "dashboard:dev": "pnpm --filter @open-agent-teams/dashboard run dev",
    "dashboard:build": "pnpm --filter @open-agent-teams/dashboard run build",
    "hermes:bootstrap": "pnpm --filter @open-agent-teams/hermes-agent run bootstrap",
    "hermes:doctor": "pnpm --filter @open-agent-teams/hermes-agent run doctor",
    "hermes:install-help": "pnpm --filter @open-agent-teams/hermes-agent run install-help"
  },
  "devDependencies": {
    "typescript": "5.3.3"
  }
}
