# AI-local-OS — 环境变量占位
# 复制为 .env 或接入 Gateway/Hermes 宿主的环境；勿将含真实密钥的 .env 提交 Git。

# --- Hermes 实例基址（示例，按 hermes-instances 配置对齐）---
HERMES_LIFE_BASE_URL=http://127.0.0.1:8001
HERMES_DEV_BASE_URL=http://127.0.0.1:8002
HERMES_RESEARCH_BASE_URL=http://127.0.0.1:8003

# --- API Key（由 Hermes 网关签发；仅示例变量名）---
# HERMES_LIFE_API_KEY=
# HERMES_DEV_API_KEY=
# HERMES_RESEARCH_API_KEY=

# --- Gateway 侧（若产品支持从环境读取插件密钥）---
# OPENCLAW_PLUGIN_SECRET=
