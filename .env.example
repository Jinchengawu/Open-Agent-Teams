# Open-Agent-Teams 环境变量配置
# 复制此文件为 .env 并填写真实值
# ⚠️ 勿将 .env 文件提交到 Git

# 模型配置（Agent 直连 API）
MODEL_PROVIDER=deepseek
MODEL_NAME=mimo-v2.5-pro
MODEL_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# API Key（Agent 直连 API 用）
# API_KEY=your_api_key_here

# Agent 端口配置（下游工程可覆盖）
FRONTEND_AGENT_PORT=8201
BACKEND_AGENT_PORT=8202
TESTING_AGENT_PORT=8203
DEVOPS_AGENT_PORT=8204
PM_AGENT_PORT=8205

# Gateway 配置
GATEWAY_AUTH_ENABLED=false

# Hermes 降级配置（可选）
# HERMES_ENABLED=false
